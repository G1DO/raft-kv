# Per-node config for the systemd unit. Copy to /etc/raft-kv.env on EACH
# instance and change RAFT_ID + RAFT_PEERS to match that instance.
#
# PEERS lists the OTHER two nodes as id@raftAddr@clientAddr using the instances'
# PRIVATE IPs (nodes talk to each other over the VPC), while the clientAddr is
# what a client gets told to retry against on NOT_LEADER.
#
# --- on node1 (e.g. private IP 10.0.1.11) ---
RAFT_ID=node1
RAFT_PEERS=node2@10.0.1.12:9000@10.0.1.12:8080,node3@10.0.1.13:9000@10.0.1.13:8080

# --- on node2 (10.0.1.12) ---
# RAFT_ID=node2
# RAFT_PEERS=node1@10.0.1.11:9000@10.0.1.11:8080,node3@10.0.1.13:9000@10.0.1.13:8080

# --- on node3 (10.0.1.13) ---
# RAFT_ID=node3
# RAFT_PEERS=node1@10.0.1.11:9000@10.0.1.11:8080,node2@10.0.1.12:9000@10.0.1.12:8080
