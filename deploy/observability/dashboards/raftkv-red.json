{
  "title": "raft-kv / Client API (RED)",
  "uid": "raftkv-red",
  "tags": ["raft-kv"],
  "editable": true,
  "graphTooltip": 1,
  "refresh": "10s",
  "schemaVersion": 39,
  "time": { "from": "now-30m", "to": "now" },
  "timezone": "browser",
  "templating": { "list": [] },
  "panels": [
    {
      "type": "stat",
      "title": "Request rate",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(raftkv_requests_total[1m]))", "legendFormat": "req/s", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat",
      "title": "Success ratio (5m)",
      "description": "ok / all, over every op. not_leader counts as non-success here; the SLO dashboard scopes to writes only.",
      "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(raftkv_requests_total{result=\"ok\"}[5m])) / sum(rate(raftkv_requests_total[5m]))", "legendFormat": "success", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit", "min": 0, "max": 1,
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "yellow", "value": 0.95 }, { "color": "green", "value": 0.99 } ] }
        },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat",
      "title": "p99 latency (5m)",
      "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.99, sum by (le) (rate(raftkv_request_duration_seconds_bucket[5m])))", "legendFormat": "p99", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "stat",
      "title": "Timeouts (5m rate)",
      "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum(rate(raftkv_requests_total{result=\"timeout\"}[5m]))", "legendFormat": "timeouts/s", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "thresholds": { "mode": "absolute", "steps": [ { "color": "green", "value": null }, { "color": "red", "value": 0.001 } ] }
        },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } }
    },
    {
      "type": "timeseries",
      "title": "Rate — requests by op",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by (op) (rate(raftkv_requests_total[1m]))", "legendFormat": "{{op}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "fillOpacity": 10, "stacking": { "mode": "normal" } } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries",
      "title": "Errors — non-ok results by class",
      "description": "not_leader = client hit a follower (redirect, not a failure); timeout = commit/read-index wait exceeded; error = protocol/other.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "sum by (result) (rate(raftkv_requests_total{result!=\"ok\"}[1m]))", "legendFormat": "{{result}}", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "fillOpacity": 10 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "multi" } }
    },
    {
      "type": "timeseries",
      "title": "Duration — p50 / p99 by op",
      "description": "Traces carry the exemplar-level story: raft.append vs raft.replicate_commit_apply spans split this same time by pipeline stage.",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum by (le, op) (rate(raftkv_request_duration_seconds_bucket[5m])))", "legendFormat": "p50 {{op}}", "refId": "A" },
        { "expr": "histogram_quantile(0.99, sum by (le, op) (rate(raftkv_request_duration_seconds_bucket[5m])))", "legendFormat": "p99 {{op}}", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "fillOpacity": 5 } }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "placement": "right", "calcs": ["lastNotNull", "max"] }, "tooltip": { "mode": "multi" } }
    }
  ]
}
